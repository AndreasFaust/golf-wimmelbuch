# Öffentliche URL der Website (für Canonical- und OG-URLs)
NUXT_PUBLIC_SITE_URL=https://example.com

# SMTP für Bestätigungs-E-Mail an den Antragsteller
# und Benachrichtigung an die Operatoren
NUXT_SMTP_HOST=mail.example.com
# 587 = STARTTLS, 465 = TLS (NUXT_SMTP_SECURE entsprechend setzen)
NUXT_SMTP_PORT=587
NUXT_SMTP_SECURE=false
NUXT_SMTP_USER=
NUXT_SMTP_PASSWORD=your_password_here
# Absender-Adresse. Anzeigename wird je nach Locale automatisch gesetzt
# („Golf-Wimmelbuch" / „Golf Search-and-Find Book").
NUXT_SMTP_FROM=
# Empfänger der Operator-Benachrichtigung (mindestens einer erforderlich)
NUXT_SMTP_OPERATOR1=
NUXT_SMTP_OPERATOR2=
