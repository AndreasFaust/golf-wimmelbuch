# SMTP für Bestätigungs-E-Mail an den Antragsteller
# und Benachrichtigung an den Operator
NUXT_SMTP_HOST=mail.example.com
# 587 = STARTTLS, 465 = TLS (NUXT_SMTP_SECURE entsprechend setzen)
NUXT_SMTP_PORT=587
NUXT_SMTP_SECURE=false
NUXT_SMTP_USER=info@faust-kommunikation.de
NUXT_SMTP_PASSWORD=your_password_here
# Absender-Adresse. Wird auch als Empfänger der Operator-Benachrichtigung
# verwendet. Anzeigename wird je nach Locale automatisch gesetzt
# („Golf-Wimmelbuch" / „Golf Search-and-Find Book").
NUXT_SMTP_FROM=info@faust-kommunikation.de
